From: Lucas <user@domain>
Subject: asteroid-app: Add missing qtbase dependency

Asteroid apps need qtbase to access basic Qt headers like QObject.
Without this dependency, compilation fails with "QObject: No such file or directory".

Upstream-Status: Pending

--- a/recipes-asteroid/asteroid-apps/asteroid-app.inc
+++ b/recipes-asteroid/asteroid-apps/asteroid-app.inc
@@ -5,7 +5,7 @@
 S = "${WORKDIR}/git"
 inherit cmake_qt5

-DEPENDS += "qml-asteroid asteroid-generate-desktop-native qttools-native qtdeclarative-native"
+DEPENDS += "qml-asteroid asteroid-generate-desktop-native qttools-native qtdeclarative-native qtbase"
 FILES:${PN} += "/usr/share/translations/ ${libdir}/${PN}.so"

 REMOVE_TRANSLATIONS ?= "0"
